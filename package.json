{
  "name": "dicha-workspace",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev:client": "pnpm --filter @dicha/client dev",
    "dev:admin": "pnpm --filter @dicha/admin dev",
    "build": "pnpm build:client && pnpm build:admin",
    "build:client": "pnpm --filter @dicha/client build",
    "build:admin": "pnpm --filter @dicha/admin build",
    "lint": "pnpm lint:client && pnpm lint:admin",
    "lint:client": "pnpm --filter @dicha/client lint",
    "lint:admin": "pnpm --filter @dicha/admin lint",
    "preview:client": "pnpm --filter @dicha/client preview",
    "preview:admin": "pnpm --filter @dicha/admin preview",
    "audit:colors": "pnpm --filter @dicha/client audit:colors",
    "format": "pnpm --filter @dicha/client format"
  },
  "packageManager": "pnpm@10.24.0"
}
